{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "database.json"
    },
    "api/handler.ts": {
      "includeFiles": "database.json"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/handler" }
  ]
}
